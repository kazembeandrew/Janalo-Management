VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_GOOGLE_API_KEY=

# Optional (for fully automated SQL migrations without needing an exec_sql RPC)
# Use the Supabase project's Postgres connection string (keep secret).
SUPABASE_DB_URL=

# Alternative (recommended if your password has special characters):
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# Optional (used by backend/ clean-architecture prototype)
# Prefer `REDIS_URL` for managed Redis (supports `rediss://`).
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=janalo:

# Cache TTLs (seconds)
CACHE_TTL_ACCOUNT_BALANCE=300
CACHE_TTL_TRIAL_BALANCE=600
CACHE_TTL_USER_PERMISSIONS=1800
CACHE_TTL_REPORTS=900
